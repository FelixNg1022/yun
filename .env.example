# Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Your iMessage phone number in E.164 format (e.g. +16045551234)
OWNER_PHONE=

# Your birth timestamp with timezone offset (ISO 8601)
OWNER_BIRTH=2002-10-22T18:00:00+08:00

# Your birth city (free text, used as onboarding default)
OWNER_BIRTH_CITY=Shenzhen

# Days until follow-up check-in is scheduled after a reading (default: 5)
FOLLOW_UP_DAYS=5
